{
  "name": "@mossrussell/context-ledger",
  "version": "1.2.1",
  "description": "Decision capture and retrieval system for AI-assisted development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-ledger": "dist/cli.js",
    "context-ledger-mcp": "dist/mcp-server-bin.js",
    "context-ledger-setup": "dist/setup.js"
  },
  "files": [
    "dist/",
    "examples/",
    "README.md",
    "QUICKSTART.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "start": "node dist/cli.js",
    "smoke": "node dist/smoke.js",
    "setup": "node dist/setup.js",
    "prepublishOnly": "npm run rebuild",
    "gen:api-routes": "node scripts/generate-api-inventory.cjs",
    "gen:env": "node scripts/generate-env-inventory.cjs",
    "gen:all": "npm run gen:api-routes && npm run gen:env",
    "test:integration": "node dist/ledger/smoke-test.js",
    "test:retrieval": "node dist/retrieval/smoke-test.js",
    "test:dogfood": "node dist/ledger/dogfood.js",
    "test:mcp": "node dist/mcp/smoke-test.js",
    "test:drafter": "node dist/capture/drafter.test.js",
    "test:hook": "node dist/capture/hook.test.js",
    "test:classify": "node dist/capture/smoke-test.js && node dist/capture/classify.test.js",
    "test": "npm run test:integration && npm run test:retrieval && npm run test:mcp && npm run test:classify && npm run test:drafter && npm run test:hook",
    "smoke:drafter": "tsx src/smoke-drafter.ts",
    "prepare": "npx husky",
    "postcommit": "node dist/capture/hook.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "ISC",
  "author": "Russell Moss",
  "repository": {
    "type": "git",
    "url": "https://github.com/russellmoss/context-ledger"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mossrussell/agent-guard": "^0.6.3",
    "@types/node": "^25.5.0",
    "dotenv": "^17.4.2",
    "is-odd": "^3.0.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
