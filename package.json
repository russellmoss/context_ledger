{
  "name": "context-ledger",
  "version": "0.1.0",
  "description": "Decision capture and retrieval system for AI-assisted development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-ledger": "dist/cli.js",
    "context-ledger-mcp": "dist/mcp-server.js",
    "context-ledger-setup": "dist/setup.js"
  },
  "files": [
    "dist/",
    "examples/",
    "README.md",
    "QUICKSTART.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "start": "node dist/cli.js",
    "smoke": "node dist/smoke.js",
    "setup": "node dist/setup.js",
    "prepublishOnly": "npm run rebuild"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "ISC",
  "author": "Russell Moss",
  "repository": {
    "type": "git",
    "url": "https://github.com/russellmoss/context-ledger"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
